      "name": "Zendure Solarflow 800 Pro – inverter",
      "entries": {
        "current_dc_power": {
          "urlExtension": "/properties/report",
          "httpMethod": "GET",
          "responseType": "JSON",
          "dataPath": "$.properties.solarInputPower",
          "scaleFactor": 1,
          "formula": "0",
          "parameterType": {
            "primitive": "double"
          }
